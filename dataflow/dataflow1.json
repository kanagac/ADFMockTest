{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "src"
				},
				{
					"name": "target"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "cleansrc"
				},
				{
					"name": "transformedtgt"
				},
				{
					"name": "join1"
				},
				{
					"name": "split1"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> src",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> target",
				"src derive() ~> cleansrc",
				"target derive() ~> transformedtgt",
				"cleansrc, transformedtgt join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 split(isNull(),",
				"     ERROR_FUNCTION('!isNull() && '),",
				"     ERROR_FUNCTION(''),",
				"     disjoint: false) ~> split1@(NEW, UPDATED, INSERT, DEFAULT)"
			]
		}
	}
}