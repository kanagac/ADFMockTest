{
	"name": "DF_Title_IN1727",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_SRC_IN1727",
						"type": "DatasetReference"
					},
					"name": "SourceTitle"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_TGT_IN1727",
						"type": "DatasetReference"
					},
					"name": "LoadTarget"
				}
			],
			"transformations": [
				{
					"name": "DataTransformation"
				},
				{
					"name": "TargetColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          title_id as string,",
				"          title as string,",
				"          type as string,",
				"          pub_id as string,",
				"          price as decimal(10,4),",
				"          advance as decimal(10,4),",
				"          royalty as integer,",
				"          ytd_sales as integer,",
				"          notes as string,",
				"          pubdate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceTitle",
				"TargetColumns derive(Title_ID = concat('T-', Title_ID, '-001'),",
				"          Title_Desc = concat(\r",
				"    upper(Type),\r",
				"    '-',\r",
				"    upper(Title_Desc)\r",
				"),",
				"          Type = concat(\r",
				"    'TT-',\r",
				"    initCap(Type)\r",
				"),",
				"          Pub_ID = trim(upper(Pub_ID)),",
				"          Price = case(\r",
				"    Price < 2, Price * 0.30,\r",
				"    Price * 0.10\r",
				"),",
				"          Notes = concat(\r",
				"    substring(Notes, 0, 3),\r",
				"    substring(Notes, length(Notes) - 2, 2)\r",
				"    )) ~> DataTransformation",
				"SourceTitle select(mapColumn(",
				"          Title_ID = title_id,",
				"          Title_Desc = title,",
				"          Type = type,",
				"          Pub_ID = pub_id,",
				"          Price = price,",
				"          Notes = notes,",
				"          Publish_Date = pubdate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> TargetColumns",
				"DataTransformation sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          Title_ID,",
				"          Title_Desc,",
				"          Type,",
				"          Pub_ID,",
				"          Price,",
				"          Notes,",
				"          Publish_Date",
				"     )) ~> LoadTarget"
			]
		}
	}
}