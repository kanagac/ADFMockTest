{
	"name": "DF_STORES",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_TGT_IN1723",
						"type": "DatasetReference"
					},
					"name": "SrcStores"
				},
				{
					"dataset": {
						"referenceName": "DS_TGT_IN1723",
						"type": "DatasetReference"
					},
					"name": "TgtStores"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SRC_IN1723",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_TGT_IN1723",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "JOINLEFTSTORES"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "split1"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SrcStores",
				"source(output(",
				"          Store_key as integer,",
				"          Store_Id as string,",
				"          Store_name as string,",
				"          Store_address as string,",
				"          Store_city as string,",
				"          Store_state as string,",
				"          Store_zip as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TgtStores",
				"SrcStores join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JOINLEFTSTORES",
				"JOINLEFTSTORES derive() ~> derivedColumn1",
				"derivedColumn1 split(ERROR_FUNCTION(''),",
				"     disjoint: false) ~> split1@(insert, update)",
				"split1@update alterRow() ~> alterRow1",
				"split1@insert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink2"
			]
		}
	}
}