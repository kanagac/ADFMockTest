{
	"name": "DF_TITLE_IN1742",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_source_IN1742",
						"type": "DatasetReference"
					},
					"name": "SourceTitle"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TARGET_COMMON",
						"type": "DatasetReference"
					},
					"name": "LoadingTarget"
				}
			],
			"transformations": [
				{
					"name": "ProcessingTitle"
				},
				{
					"name": "loadOnlyBefore2021"
				}
			],
			"scriptLines": [
				"source(output(",
				"          title_id as string,",
				"          title as string,",
				"          type as string,",
				"          pub_id as string,",
				"          price as decimal(10,4),",
				"          advance as decimal(10,4),",
				"          royalty as integer,",
				"          ytd_sales as integer,",
				"          notes as string,",
				"          pubdate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceTitle",
				"loadOnlyBefore2021 derive(title_id = concat('T-',title_id,'-001'),",
				"          title_desc = concat(upper(type), '-',upper(title)),",
				"          type = concat('TT-', initCap(type)),",
				"          pub_id = upper(trim(pub_id)),",
				"          price = iif(price<2,price+(price*0.3),price+(price*0.1)),",
				"          notes = concat(notes,left(notes, 3),right(notes, 2)),",
				"          pubdate = concat(toString(year(pubdate)),toString(month(pubdate)),toString(dayOfMonth(pubdate)))) ~> ProcessingTitle",
				"SourceTitle filter(year(pubdate) <2021) ~> loadOnlyBefore2021",
				"ProcessingTitle sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          title_id,",
				"          title,",
				"          type,",
				"          pub_id,",
				"          price,",
				"          advance,",
				"          royalty,",
				"          ytd_sales,",
				"          notes,",
				"          pubdate,",
				"          title_desc",
				"     )) ~> LoadingTarget"
			]
		}
	}
}