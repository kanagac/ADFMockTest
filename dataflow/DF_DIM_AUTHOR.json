{
	"name": "DF_DIM_AUTHOR",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_AUTHORS",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_DIM_AUTHORS",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          au_id as string,",
				"          au_lname as string,",
				"          au_fname as string,",
				"          phone as string,",
				"          address as string,",
				"          city as string,",
				"          state as string,",
				"          zip as string,",
				"          contract as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"select1 derive(au_lname = concatWS('-',left(au_lname,1), au_fname),",
				"          AUTHOR_PHONE = concat('+91-(',left(AUTHOR_PHONE,3),')-(',substring(AUTHOR_PHONE,4,3),')-',right(AUTHOR_PHONE,4)),",
				"          AUTHOR_ADDRESS = regexReplace(replace(AUTHOR_ADDRESS,\" \",\",\"),\"[0-9]\",\"\"),",
				"          AUTHOR_STATE = upper(trim(AUTHOR_STATE)),",
				"          AUTHOR_ZIP = case(length(AUTHOR_ZIP) < 6, concat(left(AUTHOR_ZIP,3),\" \",right(AUTHOR_ZIP,2),\"0\")),",
				"          AU_CONTRACT_STATUS = iif(AU_CONTRACT_STATUS == '1',\"Active\",\"De-Active\")) ~> derivedColumn1",
				"source1 select(mapColumn(",
				"          au_lname,",
				"          au_fname,",
				"          AUTHOR_PHONE = phone,",
				"          AUTHOR_ADDRESS = address,",
				"          AUTHOR_CITY = city,",
				"          AUTHOR_STATE = state,",
				"          AUTHOR_ZIP = zip,",
				"          AU_CONTRACT_STATUS = contract",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn1 select(mapColumn(",
				"          AUTHOR_NAME = au_lname,",
				"          AUTHOR_PHONE,",
				"          AUTHOR_ADDRESS,",
				"          AUTHOR_CITY,",
				"          AUTHOR_STATE,",
				"          AUTHOR_ZIP,",
				"          AU_CONTRACT_STATUS",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}