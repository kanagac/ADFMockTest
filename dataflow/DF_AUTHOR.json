{
	"name": "DF_AUTHOR",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SRC_IN1723",
						"type": "DatasetReference"
					},
					"name": "SrcAuthor"
				},
				{
					"dataset": {
						"referenceName": "DS_TGT_IN1723",
						"type": "DatasetReference"
					},
					"name": "TgtAuthor"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TGT_IN1723",
						"type": "DatasetReference"
					},
					"name": "SNKAUTHOR"
				}
			],
			"transformations": [
				{
					"name": "JOINLEFTAUTHOR"
				},
				{
					"name": "Transformation"
				}
			],
			"scriptLines": [
				"source(output(",
				"          au_id as string,",
				"          au_lname as string,",
				"          au_fname as string,",
				"          phone as string,",
				"          address as string,",
				"          city as string,",
				"          state as string,",
				"          zip as string,",
				"          contract as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SrcAuthor",
				"source(output(",
				"          Author_Name as string,",
				"          Author_Phone as string,",
				"          Author_Address as string,",
				"          Author_City as string,",
				"          Author_State as string,",
				"          Author_Zip as string,",
				"          AU_Contract_Status as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TgtAuthor",
				"SrcAuthor, TgtAuthor join(phone == Author_Phone,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JOINLEFTAUTHOR",
				"JOINLEFTAUTHOR derive(startdate = currentDate()) ~> Transformation",
				"Transformation sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SNKAUTHOR"
			]
		}
	}
}